# Public URL settings (used for CORS and magic-link URLs)
APP_HOST=contest.mareate.com
APP_SCHEME=https
APP_PORT=80

# Backend runtime
NODE_ENV=production
PORT=3001

# MongoDB
MONGO_ROOT_USERNAME=busybee
MONGO_ROOT_PASSWORD=replace-with-strong-password
MONGO_DATABASE=busybee
MONGODB_URI=mongodb://busybee:replace-with-strong-password@mongo:27017/busybee?authSource=admin

# Auth
JWT_SECRET=replace-with-a-random-string-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS and frontend URL for email links
CORS_ORIGINS=https://contest.mareate.com
FRONTEND_URL=https://contest.mareate.com

# Email (magic-link login depends on SMTP)
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=admin@example.com
SMTP_PASSWORD=replace-with-smtp-app-password
EMAIL_FROM="BusyBee <admin@example.com>"
EMAIL_SECURE=true

# Optional comma-separated domains
ALLOWED_EMAIL_DOMAINS=
