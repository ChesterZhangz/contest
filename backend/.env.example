# 服务
PORT=3001
NODE_ENV=development

# 数据库
MONGODB_URI=mongodb://127.0.0.1:27017/math_competition

# 认证
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS（多个来源用逗号分隔）
CORS_ORIGINS=http://localhost:5173

# 前端地址（用于邮件中的魔法链接）
FRONTEND_URL=http://localhost:5173

# Email (SMTP) - 腾讯企业邮箱
# 注意：EMAIL_FROM 必须使用 SMTP_USER 的邮箱地址，否则邮件无法发送
SMTP_HOST=smtp.exmail.qq.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM="BusyBee <noreply@example.com>"
EMAIL_SECURE=true

# 可选：限制可注册邮箱域名（逗号分隔）
ALLOWED_EMAIL_DOMAINS=
